// DecCu.cpp 상단 include 근처
#include <fstream>
#include <mutex>
#include <iomanip>

static std::mutex g_decCuLogMutex;

static const char* predModeName( PredMode mode )
{
  switch( mode )
  {
  case MODE_INTER: return "INTER";
  case MODE_INTRA: return "INTRA";
#if JVET_S0078
  case MODE_IBC:   return "IBC";
#endif
  default:         return "UNKNOWN";
  }
}

static void dumpMv( std::ofstream& ofs, const char* name, const Mv& mv )
{
  ofs << name << "=(" << mv.getHor() << "," << mv.getVer() << ") ";
}

static void dumpDecCuInfo( const CodingUnit& cu, const char* tag )
{
  std::lock_guard<std::mutex> lock( g_decCuLogMutex );

  std::ofstream ofs( "dec_cu_debug.txt", std::ios::app );
  if( !ofs.is_open() ) return;

  const Position pos  = cu.lumaPos();
  const Size     size = cu.lumaSize();

  const int poc = cu.slice ? cu.slice->getPOC() : -999;

  ofs << "==============================\n";
  ofs << "[DEC_CU] tag=" << tag
      << " POC=" << poc
      << " x=" << pos.x
      << " y=" << pos.y
      << " w=" << size.width
      << " h=" << size.height
      << "\n";

  ofs << "CU_SYNTAX "
      << "predMode=" << predModeName( cu.predMode )
      << " qp=" << (int)cu.qp
      << " skip=" << (int)cu.skip
      << " rootCbf=" << (int)cu.rootCbf
      << " affine=" << (int)cu.affine
      << " affineType=" << (int)cu.affineType
      << " imv=" << (int)cu.imv
      << " mmvdSkip=" << (int)cu.mmvdSkip
      << "\n";

  // 네가 추가한 depth tool flag가 있으면 여기에 추가
  // 예:
  // ofs << "DEPTH "
  //     << "depthFlag=" << (int)cu.depthFlag
  //     << " depthMerge=" << (int)cu.depthMergeFlag
  //     << " depthSkip=" << (int)cu.depthSkipFlag
  //     << "\n";

  int puIdx = 0;

  for( const PredictionUnit* pu = cu.firstPU; pu != nullptr; pu = pu->next, puIdx++ )
  {
    ofs << "PU[" << puIdx << "] "
        << "x=" << pu->lumaPos().x
        << " y=" << pu->lumaPos().y
        << " w=" << pu->lumaSize().width
        << " h=" << pu->lumaSize().height
        << " mergeFlag=" << (int)pu->mergeFlag
        << " regularMergeFlag=" << (int)pu->regularMergeFlag
        << " mmvdMergeFlag=" << (int)pu->mmvdMergeFlag
        << " mmvdMergeIdx=" << (int)pu->mmvdMergeIdx
        << " mergeIdx=" << (int)pu->mergeIdx
        << " interDir=" << (int)pu->interDir
        << " refIdxL0=" << (int)pu->refIdx[REF_PIC_LIST_0]
        << " refIdxL1=" << (int)pu->refIdx[REF_PIC_LIST_1]
        << " ciipFlag=" << (int)pu->ciipFlag
        << " geoFlag=" << (int)pu->geoFlag
        << "\n";

    ofs << "  MV ";
    dumpMv( ofs, "mvL0",  pu->mv [REF_PIC_LIST_0] );
    dumpMv( ofs, "mvL1",  pu->mv [REF_PIC_LIST_1] );
    dumpMv( ofs, "mvdL0", pu->mvd[REF_PIC_LIST_0] );
    dumpMv( ofs, "mvdL1", pu->mvd[REF_PIC_LIST_1] );
    ofs << "\n";

    if( cu.affine )
    {
      ofs << "  AFFINE ";
      for( int l = 0; l < 2; l++ )
      {
        const RefPicList eRefList = ( l == 0 ) ? REF_PIC_LIST_0 : REF_PIC_LIST_1;

        ofs << "L" << l << " refIdx=" << (int)pu->refIdx[eRefList] << " ";

        dumpMv( ofs, "CP0", pu->mvAffi[eRefList][0] );
        dumpMv( ofs, "CP1", pu->mvAffi[eRefList][1] );
        dumpMv( ofs, "CP2", pu->mvAffi[eRefList][2] );

#if AFFINE_MMVD
        // 필요한 경우 사용
#endif
        ofs << " ";
      }
      ofs << "\n";
    }
  }

  ofs << std::flush;
}
